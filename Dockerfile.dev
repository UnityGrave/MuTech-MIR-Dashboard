# Development Dockerfile
# Optimized for hot module reloading and live code updates

FROM node:20-alpine

# Set working directory
WORKDIR /app

# Install dependencies for native modules (if needed)
RUN apk add --no-cache python3 make g++

# Copy package files first for better layer caching
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm ci

# Copy source code (will be overridden by volume mount in compose)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Set environment variables
ENV NODE_ENV=development
ENV VITE_HMR_HOST=localhost

# Start Vite dev server with host binding for Docker access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

